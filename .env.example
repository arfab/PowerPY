# Plantilla de Configuración de Base de Datos para PowerPY
# Copia este archivo como '.env' en el mismo directorio y completa los valores.

DB_TYPE=sqlserver
DB_SERVER=tu-servidor-sql.com
DB_DATABASE=NombreDeTuBD
DB_USERNAME=tu_usuario_sql
DB_PASSWORD=tu_contraseña_sql
DB_TRUSTED_CONNECTION=no
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_PORT=1433
